{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cronplus.local/schemas/manifest.schema.json",
  "title": "CronPlus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["script", "schedule"],
  "properties": {
    "manifest_version": {
      "type": "integer",
      "minimum": 1
    },
    "script": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["system", "managed_venv", "venv_path"]
            },
            "python_base_interpreter": { "type": "string" },
            "requirements_file": { "type": "string" },
            "venv_path": { "type": "string" }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "strategy": { "const": "venv_path" }
                },
                "required": ["strategy"]
              },
              "then": {
                "required": ["venv_path"]
              }
            }
          ]
        },
        "working_directory": { "type": "string" },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "max_output_kb": { "type": "integer", "minimum": 1 },
        "env_file": { "type": "string" },
        "isolated_run": { "type": "boolean" },
        "resource_limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "graceful_kill_seconds": { "type": "integer", "minimum": 1 },
            "max_open_files": { "type": "integer", "minimum": 0 },
            "max_processes": { "type": "integer", "minimum": 0 },
            "max_cpu_seconds": { "type": "integer", "minimum": 0 },
            "max_memory_mb": { "type": "integer", "minimum": 0 }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "value"],
            "properties": {
              "type": { "type": "string", "enum": ["plain", "secret"] },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expression"],
      "properties": {
        "type": { "type": "string", "enum": ["cron"] },
        "expression": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string" },
        "missed_run_policy": { "type": "string", "enum": ["skip"] }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "send_on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["success", "failure", "failed", "warning", "skipped"]
          }
        },
        "message_template": { "type": "string" },
        "inline_profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "driver"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string" },
              "driver": { "type": "string", "minLength": 1 },
              "config": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "category": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "result_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "expect_structured_result": { "type": "boolean" },
        "result_prefix": { "type": "string", "minLength": 1 }
      }
    }
  }
}
